{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-build",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "clang-tidy",
            "type": "shell",
            "command": "powershell",
            "args": [
                "-Command",
                "Get-ChildItem -Recurse -Filter *.cpp src | ForEach-Object { clang-tidy $_.FullName -p build }"
            ],
            "group": "build",
            "problemMatcher": ["$gcc"]
        }
    ]
}