{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C++ GDB Debug",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/achilles",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "preLaunchTask": "cmake-build",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "Load Eigen pretty printers",
                    "text": "-interpreter-exec console \"source /home/fadag/.gdbinit\"",
                    "ignoreFailures": true
                }
            ]
        },
